AWS_REGION=us-east-1
# Optional: only set this if you authenticate via a named profile in
# ~/.aws/config (e.g. from `aws configure --profile myprofile`). Leave unset
# if you're using AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env vars, the
# "default" profile, or an IAM role -- setting it to a profile name that
# doesn't exist in ~/.aws/config will cause a ProfileNotFound error.
# AWS_PROFILE=myprofile
# Example only -- verify this model id is enabled for your account/region via
# `aws bedrock list-foundation-models`.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Set to true to bypass Bedrock entirely and use canned heuristic responses
# instead -- useful for exercising the pipeline/review UI with no AWS access.
# Never use this as a stand-in for real classification/decisioning quality.
# MOCK_LLM=true
